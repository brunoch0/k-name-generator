# dependencies
node_modules
.pnp
.pnp.js

# build
dist
dist-ssr
*.local

# env — NEVER commit secrets (the Anthropic key lives only in Supabase).
# .env.production holds PUBLIC build vars (Supabase URL + anon/publishable key,
# which ship in every client bundle anyway) so Vercel builds are self-contained.
.env
.env.*.local
.env.local
!.env.example
!.env.production

# supabase
supabase/.branches
supabase/.temp
.supabase

# editor / os
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.log
npm-debug.log*

# tooling state
.bkit
.vercel
