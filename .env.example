# ───────────────────────────────────────────────────────────────
# FRONTEND (Vite) — only PUBLIC values may live here.
# Copy to `.env` and fill in. NEVER put the Anthropic key here.
# ───────────────────────────────────────────────────────────────

# Your Supabase project URL, e.g. https://xxxx.supabase.co
VITE_SUPABASE_URL=

# Supabase ANON (publishable) key — safe for the browser.
VITE_SUPABASE_ANON_KEY=

# Name of the deployed edge function (default: generate-name)
VITE_GENERATE_FUNCTION=generate-name

# Optional: force the deterministic on-device generator instead of the
# edge function (handy for local demos with no Supabase project).
# "true" => never call the network. Leave blank to auto-detect.
VITE_USE_LOCAL_GENERATOR=

# Optional: Lemon Squeezy hosted-checkout URL for the hand-brushed (49 AED)
# tier. Create the product in Lemon Squeezy, set its price to 49 AED, and paste
# the "Share / Checkout" link here. Blank => the section falls back to a free
# email request instead of paid checkout.
VITE_HANDCRAFT_CHECKOUT_URL=

# ───────────────────────────────────────────────────────────────
# EDGE FUNCTION SECRETS — set these with the Supabase CLI, NOT here:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# They are listed here only for documentation.
# ───────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
